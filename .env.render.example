# REDFILM Render + Neon emergency migration env
# Put these values into Render Web Service and Worker.

NODE_ENV=production
NODE_VERSION=22

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

NEXT_PUBLIC_SITE_NAME="REDFILM"
NEXT_PUBLIC_SITE_HOST="redfilm.win"
NEXT_PUBLIC_SITE_URL="https://redfilm.win"
SITE_URL="https://redfilm.win"
NEXT_PUBLIC_APP_URL="https://redfilm.win"
REDFILM_BASE_URL="https://redfilm.win"

# Emergency safe mode. Keep this during migration / Google cleanup.
PUBLIC_INDEXING_ENABLED=false
PUBLIC_PLAYBACK_ENABLED=false
EMERGENCY_DEINDEX_MODE=true

NEXT_PUBLIC_YANDEX_METRIKA_ID=110229115

ADMIN_USERNAME=admin
ADMIN_PASSWORD="CHANGE_ME_LONG_PASSWORD"

VIBIX_API_KEY="CHANGE_ME"
VIBIX_PUBLISHER_ID=678353780
NEXT_PUBLIC_VIBIX_AD_TYPES=sticker,pcsticker,banners,flyroll

CRON_SECRET="CHANGE_ME_RANDOM_64_HEX"

OPENAI_API_KEY=""
OPENAI_SEO_MODEL=gpt-4.1-mini

TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_ADMIN_IDS=""
NEXT_PUBLIC_TELEGRAM_MINI_APP_URL=https://redfilm.win/

# Worker throttling. Safe defaults for a fresh host.
VIBIX_CATALOG_WORKER_ENABLED=true
VIBIX_CATALOG_WORKER_INTERVAL_MS=30000
VIBIX_CATALOG_PAGES_PER_RUN=5
VIBIX_CATALOG_IMPORT_BATCH_SIZE=50
VIBIX_CATALOG_PAGE_DELAY_MS=7000
VIBIX_CATALOG_429_MIN_COOLDOWN_MS=300000
VIBIX_CATALOG_429_MAX_COOLDOWN_MS=1800000
VIBIX_CATALOG_SOFT_PAGES_PER_RUN=5
VIBIX_CATALOG_SOFT_PAGE_DELAY_MS=7000
VIBIX_CATALOG_ERROR_COOLDOWN_MS=180000
SIMILARITY_WORKER_ENABLED=true
SIMILARITY_RECALCULATE_BATCH_SIZE=75
TREND_SYNC_ENABLED=true
TREND_SYNC_BATCH_SIZE=30
TREND_CHECK_BATCH_SIZE=30
