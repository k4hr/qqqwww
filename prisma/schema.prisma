generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentType {
  MOVIE
  SERIES
  CARTOON
  ANIME
}

enum MovieArtworkType {
  BACKDROP
  POSTER
  LOGO
}

enum ProviderName {
  ALLOHA
  TRAILER
  MANUAL
}

model Movie {
  id                       String                     @id @default(cuid())
  slug                     String                     @unique
  titleRu                  String
  titleOriginal            String?
  description              String                     @db.Text
  year                     Int
  type                     ContentType                @default(MOVIE)
  posterUrl                String?
  backdropUrl              String?
  trailerUrl               String?
  country                  String?
  director                 String?
  ageRating                String?
  quality                  String                     @default("WEB-DL")
  duration                 Int?
  kinopoiskId              String?
  imdbId                   String?
  tmdbId                   String?
  allohaId                 String?
  vibixId                  Int?
  vibixIframeUrl           String?
  vibixEmbedCode           String?
  vibixAvailable           Boolean                    @default(false)
  vibixType                String?
  vibixUploadedAt          DateTime?
  vibixUpdatedAt           DateTime?
  vibixLastSyncAt          DateTime?
  vibixTags                String[]                   @default([])
  vibixVoiceovers          String[]                   @default([])
  vibixLgbtContent         Int?
  vibixSeasonCount         Int?
  vibixEpisodeCount        Int?
  isCatalogAllowed         Boolean                    @default(true)
  catalogBlockReason       String?
  normalizedCountries      String[]                   @default([])
  catalogCheckedAt         DateTime?
  kpRating                 Float?
  imdbRating               Float?
  tmdbRating               Float?
  kpVotes                  Int?
  imdbVotes                Int?
  tmdbVotes                Int?
  tmdbPopularity           Float?
  homeScore                Float                      @default(0)
  trendScore               Float                      @default(0)
  qualityScore             Float                      @default(0)
  catalogScore             Float                      @default(0)
  popularScore             Float                      @default(0)
  topScore                 Float                      @default(0)
  freshScore               Float                      @default(0)
  evergreenScore           Float                      @default(0)
  articleMentionScore      Float                      @default(0)
  franchiseScore           Float                      @default(0)
  actorPowerScore          Float                      @default(0)
  isHomeEligible           Boolean                    @default(false)
  isHeroEligible           Boolean                    @default(false)
  isTrendingEligible       Boolean                    @default(false)
  isEvergreenEligible      Boolean                    @default(false)
  isPublicVisible          Boolean                    @default(false)
  isPopularEligible        Boolean                    @default(false)
  isTopEligible            Boolean                    @default(false)
  isFreshEligible          Boolean                    @default(false)
  isQualityDataComplete    Boolean                    @default(false)
  lastTrendSyncAt          DateTime?
  lastQualitySyncAt        DateTime?
  lastCatalogScoreAt       DateTime?
  similarityCalculatedAt   DateTime?
  similarityDirty          Boolean                    @default(true)
  similarityDirtyReason    String?
  lastVibixEnrichedAt      DateTime?
  lastVibixSeenAt          DateTime?
  lastExternalEnrichmentAt DateTime?
  isPublished              Boolean                    @default(true)
  views                    Int                        @default(0)
  likes                    Int                        @default(0)
  dislikes                 Int                        @default(0)
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  genres                   MovieGenre[]
  cast                     MovieCast[]
  providerLinks            ProviderLink[]
  telegramFavorites        TelegramFavorite[]
  telegramHistory          TelegramWatchHistory[]
  homeSelectionItems       RedfilmHomeSelectionItem[]
  artworks                 MovieArtwork[]

  @@index([type, year])
  @@index([isPublished])
  @@index([kinopoiskId])
  @@index([imdbId])
  @@index([vibixAvailable, isPublished])
  @@index([year])
  @@index([createdAt])
  @@index([kpRating])
  @@index([isCatalogAllowed])
  @@index([isCatalogAllowed, createdAt])
  @@index([isCatalogAllowed, type, createdAt])
  @@index([isCatalogAllowed, kpRating])
  @@index([isHomeEligible, homeScore])
  @@index([isHeroEligible, homeScore])
  @@index([isTrendingEligible, trendScore])
  @@index([isPublicVisible, catalogScore])
  @@index([isPopularEligible, popularScore])
  @@index([isTopEligible, topScore])
  @@index([isFreshEligible, freshScore])
  @@index([similarityDirty, similarityCalculatedAt])
}

model Genre {
  id     String       @id @default(cuid())
  slug   String       @unique
  name   String       @unique
  movies MovieGenre[]
}

model MovieGenre {
  movieId String
  genreId String
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
}

model Person {
  id           String      @id @default(cuid())
  nameRu       String
  nameOriginal String?
  photoUrl     String?
  tmdbId       String?
  kinopoiskId  String?
  cast         MovieCast[]
}

model MovieCast {
  movieId   String
  personId  String
  role      String?
  sortOrder Int     @default(0)
  movie     Movie   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  person    Person  @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([movieId, personId])
}

model ProviderLink {
  id            String       @id @default(cuid())
  provider      ProviderName
  movieId       String
  externalId    String?
  embedUrl      String?
  isAvailable   Boolean      @default(false)
  lastCheckedAt DateTime?
  movie         Movie        @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([provider, isAvailable])
}

model MovieArtwork {
  id          String           @id @default(cuid())
  movieId     String
  type        MovieArtworkType
  source      String
  filePath    String?
  url         String
  width       Int?
  height      Int?
  aspectRatio Float?
  language    String?
  voteAverage Float?
  voteCount   Int?
  sortOrder   Int              @default(0)
  isPrimary   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  movie       Movie            @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([movieId, type, url])
  @@index([movieId, type, isPrimary, sortOrder])
}

model VibixAdSettings {
  id                String   @id @default(cuid())
  singletonKey      String   @unique @default("default")
  enabled           Boolean  @default(true)
  publisherId       String?
  scriptUrl         String?  @default("https://v-js-menu.run/public/lib.en.min.js")
  stickerEnabled    Boolean  @default(true)
  pcStickerEnabled  Boolean  @default(true)
  bannersEnabled    Boolean  @default(true)
  brandEnabled      Boolean  @default(false)
  flyrollEnabled    Boolean  @default(true)
  flyrollPosition   Int      @default(2)
  flyrollManualSlot String   @default("auto")
  bannerSlotsJson   Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model VibixUpdateCursor {
  id                 String      @id @default(cuid())
  type               ContentType
  source             String      @default("vibix")
  mode               String      @default("updates")
  lastPage           Int         @default(1)
  lastSeenUploadedAt DateTime?
  lastSeenUpdatedAt  DateTime?
  lastRunAt          DateTime?
  lastSuccessAt      DateTime?
  lastError          String?     @db.Text
  isRunning          Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([type, source, mode])
  @@index([lastRunAt])
}

model CatalogEngineRun {
  id         String    @id @default(cuid())
  status     String
  mode       String
  found      Int       @default(0)
  imported   Int       @default(0)
  updated    Int       @default(0)
  enriched   Int       @default(0)
  skipped    Int       @default(0)
  failed     Int       @default(0)
  message    String?   @db.Text
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([status, mode, createdAt])
}

model VibixSyncJob {
  id               String    @id @default(cuid())
  status           String    @default("QUEUED")
  mode             String    @default("full")
  contentType      String    @default("both")
  currentType      String    @default("movie")
  nextPage         Int       @default(1)
  lastPage         Int?
  total            Int?
  limit            Int       @default(20)
  pageDelayMs      Int       @default(10000)
  detailDelayMs    Int       @default(2000)
  imported         Int       @default(0)
  updated          Int       @default(0)
  skipped          Int       @default(0)
  errors           Int       @default(0)
  playerByIframe   Int       @default(0)
  playerByEmbed    Int       @default(0)
  rateLimited      Boolean   @default(false)
  rateLimitUntil   DateTime?
  lastError        String?   @db.Text
  lastFailedType   String?
  lastFailedPage   Int?
  lastFailedAt     DateTime?
  lastSkippedType  String?
  lastSkippedPage  Int?
  skippedPagesJson String?   @db.Text
  safeResumeNote   String?   @db.Text
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, createdAt])
}

model MovieSimilarity {
  id            String   @id @default(cuid())
  sourceMovieId String
  targetMovieId String
  score         Float    @default(0)
  audienceScore Float    @default(0)
  bucket        String?
  reasonsJson   String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([sourceMovieId, targetMovieId])
  @@index([sourceMovieId, score])
  @@index([targetMovieId])
  @@index([bucket])
}

model TelegramUser {
  id           String    @id @default(cuid())
  telegramId   String    @unique
  username     String?
  firstName    String?
  lastName     String?
  languageCode String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSeenAt   DateTime?

  favorites TelegramFavorite[]
  history   TelegramWatchHistory[]
  searches  TelegramSearchLog[]
}

model TelegramFavorite {
  id             String   @id @default(cuid())
  telegramUserId String
  movieId        String
  createdAt      DateTime @default(now())

  user  TelegramUser @relation(fields: [telegramUserId], references: [id], onDelete: Cascade)
  movie Movie        @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([telegramUserId, movieId])
  @@index([telegramUserId])
  @@index([movieId])
}

model TelegramWatchHistory {
  id              String   @id @default(cuid())
  telegramUserId  String
  movieId         String
  progressSeconds Int      @default(0)
  lastWatchedAt   DateTime @default(now())

  user  TelegramUser @relation(fields: [telegramUserId], references: [id], onDelete: Cascade)
  movie Movie        @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([telegramUserId, movieId])
  @@index([telegramUserId])
  @@index([movieId])
  @@index([lastWatchedAt])
}

model TelegramSearchLog {
  id              String   @id @default(cuid())
  telegramUserId  String?
  query           String
  normalizedQuery String?
  resultCount     Int      @default(0)
  createdAt       DateTime @default(now())

  user TelegramUser? @relation(fields: [telegramUserId], references: [id], onDelete: SetNull)

  @@index([telegramUserId])
  @@index([createdAt])
}

model SimilarityJob {
  id             String    @id @default(cuid())
  status         String    @default("QUEUED")
  mode           String    @default("DIRTY")
  total          Int?
  processed      Int       @default(0)
  saved          Int       @default(0)
  deleted        Int       @default(0)
  errors         Int       @default(0)
  batchSize      Int       @default(100)
  targetLimit    Int       @default(24)
  minScore       Float     @default(180)
  cursorMovieId  String?
  lastMovieTitle String?
  message        String?
  lastError      String?   @db.Text
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([mode, status])
  @@index([updatedAt])
}

model VibixCatalogAutoJob {
  id              String    @id @default(cuid())
  status          String    @default("QUEUED")
  mode            String    @default("FULL_CATALOG")
  currentStage    String    @default("REFRESH")
  currentType     String    @default("movie")
  nextPage        Int       @default(1)
  pagesPerRun     Int       @default(15)
  importBatchSize Int       @default(100)
  pageDelayMs     Int       @default(2500)
  rateLimitUntil  DateTime?
  indexed         Int       @default(0)
  present         Int       @default(0)
  missing         Int       @default(0)
  imported        Int       @default(0)
  updated         Int       @default(0)
  skipped         Int       @default(0)
  failed          Int       @default(0)
  loops           Int       @default(0)
  noNewPages      Int       @default(0)
  lastPageDone    Int?
  lastError       String?   @db.Text
  message         String?   @db.Text
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([currentStage, currentType])
  @@index([rateLimitUntil])
}

model VibixReferenceItem {
  id        String   @id @default(cuid())
  kind      String
  vibixId   Int
  name      String?
  nameEng   String?
  code      String?
  rawJson   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kind, vibixId])
  @@index([kind])
  @@index([kind, name])
  @@index([code])
}

model VibixCatalogSnapshot {
  id            String    @id @default(cuid())
  key           String    @unique
  label         String
  sourceType    String?
  filterKind    String?
  filterId      Int?
  total         Int?
  lastPage      Int?
  perPage       Int?
  lastCheckedAt DateTime?
  lastError     String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([sourceType])
  @@index([filterKind, filterId])
  @@index([lastCheckedAt])
}

model VibixCatalogIndex {
  id              String    @id @default(cuid())
  sourceType      String
  kpId            String
  categoryId      Int?
  categoryName    String?
  sourcePage      Int?
  indexSource     String    @default("kpids")
  vibixId         Int?
  imdbId          String?
  title           String?
  year            Int?
  hasPlayableLink Boolean   @default(false)
  detailAvailable Boolean?
  detailCheckedAt DateTime?
  rawJson         Json?
  importStatus    String    @default("UNKNOWN")
  importedMovieId String?
  lastImportError String?   @db.Text
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  importedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([sourceType, kpId])
  @@index([sourceType])
  @@index([sourceType, categoryId])
  @@index([indexSource])
  @@index([importStatus, sourceType])
  @@index([detailAvailable])
  @@index([kpId])
}

model MovieEvent {
  id        String   @id @default(cuid())
  movieId   String?
  type      String
  path      String?
  referrer  String?
  query     String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([movieId])
  @@index([type])
  @@index([createdAt])
}

model SearchEvent {
  id        String   @id @default(cuid())
  query     String
  results   Int      @default(0)
  createdAt DateTime @default(now())

  @@index([query])
  @@index([createdAt])
}

model TrendCandidate {
  id              String      @id @default(cuid())
  type            ContentType
  titleRu         String?
  titleOriginal   String
  year            Int?
  tmdbId          String?
  imdbId          String?
  kpId            String?
  source          String
  sourceCategory  String
  sourceRank      Int?
  sourceScore     Float       @default(0)
  tmdbPopularity  Float?
  tmdbVoteAverage Float?
  tmdbVoteCount   Int?
  posterUrl       String?
  backdropUrl     String?
  status          String      @default("PENDING")
  movieId         String?
  lastCheckedAt   DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([type, year])
  @@index([status])
  @@index([sourceCategory])
  @@index([sourceScore])
  @@index([tmdbId])
  @@index([imdbId])
  @@index([kpId])
}

model TrendSyncRun {
  id              String    @id @default(cuid())
  status          String
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  candidatesFound Int       @default(0)
  imported        Int       @default(0)
  notInVibix      Int       @default(0)
  failed          Int       @default(0)
  message         String?
  createdAt       DateTime  @default(now())
}

model ExternalArticleMention {
  id            String       @id @default(cuid())
  title         String
  url           String?
  sourceName    String?
  publishedAt   DateTime?
  detectedTitle String?
  detectedYear  Int?
  detectedType  ContentType?
  tmdbId        String?
  imdbId        String?
  kpId          String?
  mentionScore  Float        @default(0)
  rawSnippet    String?
  createdAt     DateTime     @default(now())

  @@index([tmdbId])
  @@index([imdbId])
  @@index([detectedYear])
  @@index([mentionScore])
}

model SeoKeyword {
  id              String   @id @default(cuid())
  query           String
  normalizedQuery String
  impressions     Int      @default(0)
  source          String   @default("wordstat")
  intent          String   @default("UNKNOWN")
  clusterKey      String?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([normalizedQuery, source])
  @@index([status])
  @@index([clusterKey])
  @@index([intent])
  @@index([impressions])
}

model SeoCluster {
  id           String   @id @default(cuid())
  key          String   @unique
  title        String
  intent       String
  mainQuery    String
  totalDemand  Int      @default(0)
  targetType   String   @default("COLLECTION")
  targetSlug   String
  status       String   @default("ACTIVE")
  variantsJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([intent])
  @@index([status])
  @@index([targetSlug])
  @@index([totalDemand])
}

model SeoLandingPage {
  id              String    @id @default(cuid())
  slug            String    @unique
  type            String    @default("COLLECTION")
  title           String
  h1              String
  description     String    @db.Text
  introText       String    @db.Text
  filterJson      Json?
  mainQuery       String?
  keywordVariants String[]  @default([])
  totalDemand     Int       @default(0)
  minItems        Int       @default(8)
  isIndexable     Boolean   @default(true)
  sitemapIncluded Boolean   @default(true)
  status          String    @default("ACTIVE")
  aiStatus        String    @default("NOT_GENERATED")
  aiModel         String?
  aiDraftJson     Json?
  aiGeneratedAt   DateTime?
  aiError         String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([isIndexable, sitemapIncluded])
  @@index([totalDemand])
}

enum PartnerStatus {
  ACTIVE
  PAUSED
  BLOCKED
}

enum PartnerAttributionModel {
  FIRST_CLICK_LOCKED
  LAST_CLICK
}

enum PartnerLinkTargetType {
  AUTHOR_HUB
  COLLECTION
  MOVIE
  HOME
  CUSTOM
}

enum PartnerEventType {
  LINK_CLICK
  UNIQUE_VISITOR
  RETURN_VISIT
  AUTHOR_HUB_OPEN
  COLLECTION_OPEN
  MOVIE_OPEN
  PLAYER_START
  AD_VIEW
  AD_CLICK
}

enum CreatorCollectionStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum PartnerRevenueStatus {
  DRAFT
  CALCULATED
  CONFIRMED
  CLOSED
  PAID
}

enum PartnerPayoutStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum PartnerRevenuePeriodType {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

model Partner {
  id                          String                  @id @default(cuid())
  name                        String
  publicName                  String?
  cabinetTitle                String?
  slug                        String                  @unique
  login                       String                  @unique
  passwordHash                String
  email                       String?
  avatarUrl                   String?
  coverUrl                    String?
  description                 String?                 @db.Text
  commissionPercent           Decimal                 @db.Decimal(5, 2)
  attributionDays             Int                     @default(30)
  attributionModel            PartnerAttributionModel @default(FIRST_CLICK_LOCKED)
  status                      PartnerStatus           @default(ACTIVE)
  canManageCollections        Boolean                 @default(true)
  requireCollectionModeration Boolean                 @default(true)
  showFinancials              Boolean                 @default(true)
  linksBlocked                Boolean                 @default(false)
  adminComment                String?                 @db.Text
  lastLoginAt                 DateTime?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt

  @@index([status])
  @@index([createdAt])
}

model PartnerSession {
  id         String   @id @default(cuid())
  partnerId  String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([partnerId])
  @@index([expiresAt])
}

model PartnerLoginAttempt {
  id        String   @id @default(cuid())
  login     String
  ipHash    String?
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([login, createdAt])
  @@index([ipHash, createdAt])
}

model PartnerLink {
  id           String                @id @default(cuid())
  partnerId    String
  name         String
  slug         String
  source       String?
  targetType   PartnerLinkTargetType
  targetUrl    String?
  collectionId String?
  movieId      String?
  isActive     Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([partnerId, slug])
  @@index([partnerId, isActive])
  @@index([collectionId])
  @@index([movieId])
}

model PartnerVisitor {
  id            String   @id @default(cuid())
  visitorId     String   @unique
  firstVisitAt  DateTime @default(now())
  lastVisitAt   DateTime @default(now())
  ipHash        String?
  userAgentHash String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([lastVisitAt])
}

model PartnerAttribution {
  id               String                  @id @default(cuid())
  visitorId        String
  partnerId        String
  partnerLinkId    String?
  attributionModel PartnerAttributionModel
  startedAt        DateTime                @default(now())
  expiresAt        DateTime
  isActive         Boolean                 @default(true)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([visitorId, isActive, expiresAt])
  @@index([partnerId, startedAt])
  @@index([partnerLinkId])
}

model PartnerEvent {
  id            String           @id @default(cuid())
  partnerId     String
  attributionId String?
  visitorId     String
  partnerLinkId String?
  collectionId  String?
  movieId       String?
  type          PartnerEventType
  revenueAmount Decimal?         @db.Decimal(18, 8)
  source        String?
  metadataJson  Json?
  createdAt     DateTime         @default(now())

  @@index([partnerId, createdAt])
  @@index([visitorId, createdAt])
  @@index([type, createdAt])
  @@index([partnerLinkId, createdAt])
  @@index([collectionId, createdAt])
  @@index([movieId, createdAt])
}

model CreatorHub {
  id          String   @id @default(cuid())
  partnerId   String   @unique
  title       String
  slug        String   @unique
  description String?  @db.Text
  coverUrl    String?
  isPublished Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, position])
}

model CreatorCollection {
  id                String                  @id @default(cuid())
  hubId             String
  partnerId         String
  title             String
  slug              String
  description       String?                 @db.Text
  coverUrl          String?
  position          Int                     @default(0)
  status            CreatorCollectionStatus @default(DRAFT)
  moderationComment String?                 @db.Text
  submittedAt       DateTime?
  publishedAt       DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@unique([hubId, slug])
  @@index([partnerId, status])
  @@index([hubId, position])
}

model CreatorCollectionMovie {
  id            String   @id @default(cuid())
  collectionId  String
  movieId       String
  position      Int
  authorComment String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([collectionId, movieId])
  @@index([collectionId, position])
  @@index([movieId])
}

model MonetizationRate {
  id              String    @id @default(cuid())
  playerStartRate Decimal   @db.Decimal(18, 8)
  videoViewRate   Decimal   @db.Decimal(18, 8)
  videoClickRate  Decimal   @db.Decimal(18, 8)
  currency        String    @default("USD")
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  createdAt       DateTime  @default(now())

  @@index([effectiveFrom, effectiveTo])
}

model PartnerCommissionRate {
  id            String    @id @default(cuid())
  partnerId     String
  percent       Decimal   @db.Decimal(5, 2)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  createdBy     String?

  @@index([partnerId, effectiveFrom])
}

model PartnerRevenuePeriod {
  id                        String                   @id @default(cuid())
  partnerId                 String
  periodType                PartnerRevenuePeriodType @default(CUSTOM)
  periodFrom                DateTime
  periodTo                  DateTime
  playerStarts              Int                      @default(0)
  videoViews                Int                      @default(0)
  videoClicks               Int                      @default(0)
  playerStartRateSnapshot   Decimal                  @db.Decimal(18, 8)
  videoViewRateSnapshot     Decimal                  @db.Decimal(18, 8)
  videoClickRateSnapshot    Decimal                  @db.Decimal(18, 8)
  commissionPercentSnapshot Decimal                  @db.Decimal(5, 2)
  estimatedGrossRevenue     Decimal                  @db.Decimal(18, 8)
  confirmedGrossRevenue     Decimal?                 @db.Decimal(18, 8)
  manualAdjustment          Decimal                  @default(0) @db.Decimal(18, 8)
  partnerCommission         Decimal?                 @db.Decimal(18, 8)
  currency                  String                   @default("USD")
  status                    PartnerRevenueStatus     @default(DRAFT)
  confirmedAt               DateTime?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  @@unique([partnerId, periodFrom, periodTo])
  @@index([partnerId, status])
  @@index([periodFrom, periodTo])
}

model PartnerPayout {
  id              String              @id @default(cuid())
  partnerId       String
  revenuePeriodId String?
  periodFrom      DateTime
  periodTo        DateTime
  amount          Decimal             @db.Decimal(18, 8)
  currency        String              @default("USD")
  status          PartnerPayoutStatus @default(PENDING)
  paidAt          DateTime?
  comment         String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([partnerId, status])
  @@index([revenuePeriodId])
  @@index([createdAt])
}

model RedfilmHomeSelectionSettings {
  singletonKey String   @id @default("default") @map("singleton_key")
  title        String   @default("В подборке REDFILM")
  subtitle     String?
  limit        Int      @default(8) @map("limit_count")
  mode         String   @default("MIXED")
  isEnabled    Boolean  @default(true) @map("is_enabled")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("redfilm_home_selection_settings")
}

model RedfilmHomeSelectionItem {
  id        String   @id
  movieId   String   @unique(map: "redfilm_home_selection_items_movie_id_key") @map("movie_id")
  position  Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  isPinned  Boolean  @default(false) @map("is_pinned")
  note      String?
  addedFrom String?  @map("added_from")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([isActive, isPinned, position], map: "redfilm_home_selection_items_active_position_idx")
  @@index([movieId], map: "redfilm_home_selection_items_movie_idx")
  @@map("redfilm_home_selection_items")
}
