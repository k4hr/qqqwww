generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentType {
  MOVIE
  SERIES
  CARTOON
  ANIME
}

enum ProviderName {
  ALLOHA
  TRAILER
  MANUAL
}

model Movie {
  id              String         @id @default(cuid())
  slug            String         @unique
  titleRu         String
  titleOriginal   String?
  description     String         @db.Text
  year            Int
  type            ContentType    @default(MOVIE)
  posterUrl       String?
  backdropUrl     String?
  trailerUrl      String?
  country         String?
  director        String?
  ageRating       String?
  quality         String         @default("WEB-DL")
  duration        Int?
  kinopoiskId     String?
  imdbId          String?
  tmdbId          String?
  allohaId        String?
  vibixId         Int?
  vibixIframeUrl  String?
  vibixEmbedCode  String?
  vibixAvailable  Boolean        @default(false)
  vibixType       String?
  vibixUploadedAt DateTime?
  vibixUpdatedAt  DateTime?
  vibixLastSyncAt DateTime?
  vibixTags       String[]       @default([])
  vibixVoiceovers String[]       @default([])
  vibixLgbtContent Int?
  vibixSeasonCount Int?
  vibixEpisodeCount Int?
  isCatalogAllowed Boolean        @default(true)
  catalogBlockReason String?
  normalizedCountries String[]    @default([])
  catalogCheckedAt DateTime?
  kpRating        Float?
  imdbRating      Float?
  tmdbRating      Float?
  kpVotes         Int?
  imdbVotes       Int?
  tmdbVotes       Int?
  tmdbPopularity  Float?
  homeScore       Float          @default(0)
  trendScore      Float          @default(0)
  qualityScore    Float          @default(0)
  catalogScore    Float          @default(0)
  popularScore    Float          @default(0)
  topScore        Float          @default(0)
  freshScore      Float          @default(0)
  evergreenScore  Float          @default(0)
  articleMentionScore Float      @default(0)
  franchiseScore  Float          @default(0)
  actorPowerScore Float          @default(0)
  isHomeEligible  Boolean        @default(false)
  isHeroEligible  Boolean        @default(false)
  isTrendingEligible Boolean     @default(false)
  isEvergreenEligible Boolean    @default(false)
  isPublicVisible Boolean        @default(false)
  isPopularEligible Boolean      @default(false)
  isTopEligible Boolean          @default(false)
  isFreshEligible Boolean        @default(false)
  isQualityDataComplete Boolean  @default(false)
  lastTrendSyncAt DateTime?
  lastQualitySyncAt DateTime?
  lastCatalogScoreAt DateTime?
  similarityCalculatedAt DateTime?
  similarityDirty Boolean          @default(true)
  similarityDirtyReason String?
  lastVibixEnrichedAt DateTime?
  lastVibixSeenAt DateTime?
  lastExternalEnrichmentAt DateTime?
  isPublished     Boolean        @default(true)
  views           Int            @default(0)
  likes           Int            @default(0)
  dislikes        Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  genres          MovieGenre[]
  cast            MovieCast[]
  providerLinks   ProviderLink[]

  @@index([type, year])
  @@index([isPublished])
  @@index([kinopoiskId])
  @@index([imdbId])
  @@index([vibixAvailable, isPublished])
  @@index([year])
  @@index([createdAt])
  @@index([kpRating])
  @@index([isCatalogAllowed])
  @@index([isCatalogAllowed, createdAt])
  @@index([isCatalogAllowed, type, createdAt])
  @@index([isCatalogAllowed, kpRating])
  @@index([isHomeEligible, homeScore])
  @@index([isHeroEligible, homeScore])
  @@index([isTrendingEligible, trendScore])
  @@index([isPublicVisible, catalogScore])
  @@index([isPopularEligible, popularScore])
  @@index([isTopEligible, topScore])
  @@index([isFreshEligible, freshScore])
  @@index([similarityDirty, similarityCalculatedAt])
}

model Genre {
  id     String       @id @default(cuid())
  slug   String       @unique
  name   String       @unique
  movies MovieGenre[]
}

model MovieGenre {
  movieId String
  genreId String
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
}

model Person {
  id           String      @id @default(cuid())
  nameRu       String
  nameOriginal String?
  photoUrl     String?
  tmdbId       String?
  kinopoiskId  String?
  cast         MovieCast[]
}

model MovieCast {
  movieId   String
  personId  String
  role      String?
  sortOrder Int     @default(0)
  movie     Movie   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  person    Person  @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([movieId, personId])
}

model ProviderLink {
  id            String       @id @default(cuid())
  provider      ProviderName
  movieId       String
  externalId    String?
  embedUrl      String?
  isAvailable   Boolean      @default(false)
  lastCheckedAt DateTime?
  movie         Movie        @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([provider, isAvailable])
}

model VibixAdSettings {
  id                 String   @id @default(cuid())
  singletonKey       String   @unique @default("default")
  enabled            Boolean  @default(true)
  publisherId        String?
  scriptUrl          String?  @default("https://v-js-menu.run/public/lib.en.min.js")
  stickerEnabled     Boolean  @default(true)
  pcStickerEnabled   Boolean  @default(true)
  bannersEnabled     Boolean  @default(true)
  brandEnabled       Boolean  @default(false)
  flyrollEnabled     Boolean  @default(true)
  flyrollPosition    Int      @default(2)
  flyrollManualSlot  String   @default("auto")
  bannerSlotsJson    Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model VibixUpdateCursor {
  id String @id @default(cuid())
  type ContentType
  source String @default("vibix")
  mode String @default("updates")
  lastPage Int @default(1)
  lastSeenUploadedAt DateTime?
  lastSeenUpdatedAt DateTime?
  lastRunAt DateTime?
  lastSuccessAt DateTime?
  lastError String? @db.Text
  isRunning Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, source, mode])
  @@index([lastRunAt])
}

model CatalogEngineRun {
  id String @id @default(cuid())
  status String
  mode String
  found Int @default(0)
  imported Int @default(0)
  updated Int @default(0)
  enriched Int @default(0)
  skipped Int @default(0)
  failed Int @default(0)
  message String? @db.Text
  startedAt DateTime @default(now())
  finishedAt DateTime?
  createdAt DateTime @default(now())

  @@index([status, mode, createdAt])
}

model VibixSyncJob {
  id             String    @id @default(cuid())
  status         String    @default("QUEUED")
  mode           String    @default("full")
  contentType    String    @default("both")
  currentType    String    @default("movie")
  nextPage       Int       @default(1)
  lastPage       Int?
  total          Int?
  limit          Int       @default(20)
  pageDelayMs    Int       @default(10000)
  detailDelayMs  Int       @default(2000)
  imported       Int       @default(0)
  updated        Int       @default(0)
  skipped        Int       @default(0)
  errors         Int       @default(0)
  playerByIframe Int       @default(0)
  playerByEmbed  Int       @default(0)
  rateLimited      Boolean   @default(false)
  rateLimitUntil   DateTime?
  lastError        String?   @db.Text
  lastFailedType   String?
  lastFailedPage   Int?
  lastFailedAt     DateTime?
  lastSkippedType  String?
  lastSkippedPage  Int?
  skippedPagesJson String?   @db.Text
  safeResumeNote   String?   @db.Text
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, createdAt])
}

model MovieSimilarity {
  id            String   @id @default(cuid())
  sourceMovieId String
  targetMovieId String
  score         Float    @default(0)
  audienceScore Float    @default(0)
  bucket        String?
  reasonsJson   String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([sourceMovieId, targetMovieId])
  @@index([sourceMovieId, score])
  @@index([targetMovieId])
  @@index([bucket])
}

model SimilarityJob {
  id            String   @id @default(cuid())
  status        String   @default("QUEUED")
  mode          String   @default("DIRTY")
  total         Int?
  processed     Int      @default(0)
  saved         Int      @default(0)
  deleted       Int      @default(0)
  errors        Int      @default(0)
  batchSize     Int      @default(100)
  targetLimit   Int      @default(24)
  minScore      Float    @default(180)
  cursorMovieId String?
  lastMovieTitle String?
  message       String?
  lastError     String?  @db.Text
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
  @@index([mode, status])
  @@index([updatedAt])
}



model VibixCatalogAutoJob {
  id              String   @id @default(cuid())
  status          String   @default("QUEUED")
  mode            String   @default("FULL_CATALOG")
  currentStage    String   @default("REFRESH")
  currentType     String   @default("movie")
  nextPage        Int      @default(1)
  pagesPerRun     Int      @default(15)
  importBatchSize Int      @default(100)
  pageDelayMs     Int      @default(2500)
  rateLimitUntil  DateTime?
  indexed         Int      @default(0)
  present         Int      @default(0)
  missing         Int      @default(0)
  imported        Int      @default(0)
  updated         Int      @default(0)
  skipped         Int      @default(0)
  failed          Int      @default(0)
  loops           Int      @default(0)
  lastPageDone    Int?
  lastError       String?  @db.Text
  message         String?  @db.Text
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
  @@index([currentStage, currentType])
  @@index([rateLimitUntil])
}

model VibixReferenceItem {
  id        String   @id @default(cuid())
  kind      String
  vibixId   Int
  name      String?
  nameEng   String?
  code      String?
  rawJson   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kind, vibixId])
  @@index([kind])
  @@index([kind, name])
  @@index([code])
}

model VibixCatalogSnapshot {
  id            String   @id @default(cuid())
  key           String   @unique
  label         String
  sourceType    String?
  filterKind    String?
  filterId      Int?
  total         Int?
  lastPage      Int?
  perPage       Int?
  lastCheckedAt DateTime?
  lastError     String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sourceType])
  @@index([filterKind, filterId])
  @@index([lastCheckedAt])
}

model VibixCatalogIndex {
  id              String   @id @default(cuid())
  sourceType      String
  kpId            String
  categoryId      Int?
  categoryName    String?
  sourcePage      Int?
  indexSource     String   @default("kpids")
  vibixId         Int?
  imdbId          String?
  title           String?
  year            Int?
  hasPlayableLink Boolean  @default(false)
  detailAvailable Boolean?
  detailCheckedAt DateTime?
  rawJson         Json?
  importStatus    String   @default("UNKNOWN")
  importedMovieId String?
  lastImportError String?  @db.Text
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  importedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([sourceType, kpId])
  @@index([sourceType])
  @@index([sourceType, categoryId])
  @@index([indexSource])
  @@index([importStatus, sourceType])
  @@index([detailAvailable])
  @@index([kpId])
}

model MovieEvent {
  id        String   @id @default(cuid())
  movieId   String?
  type      String
  path      String?
  referrer  String?
  query     String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([movieId])
  @@index([type])
  @@index([createdAt])
}

model SearchEvent {
  id        String   @id @default(cuid())
  query     String
  results   Int      @default(0)
  createdAt DateTime @default(now())

  @@index([query])
  @@index([createdAt])
}

model TrendCandidate {
  id              String      @id @default(cuid())
  type            ContentType
  titleRu         String?
  titleOriginal   String
  year            Int?
  tmdbId          String?
  imdbId          String?
  kpId            String?
  source          String
  sourceCategory  String
  sourceRank      Int?
  sourceScore     Float       @default(0)
  tmdbPopularity  Float?
  tmdbVoteAverage Float?
  tmdbVoteCount   Int?
  posterUrl       String?
  backdropUrl     String?
  status          String      @default("PENDING")
  movieId         String?
  lastCheckedAt   DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([type, year])
  @@index([status])
  @@index([sourceCategory])
  @@index([sourceScore])
  @@index([tmdbId])
  @@index([imdbId])
  @@index([kpId])
}

model TrendSyncRun {
  id              String   @id @default(cuid())
  status          String
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  candidatesFound Int      @default(0)
  imported        Int      @default(0)
  notInVibix      Int      @default(0)
  failed          Int      @default(0)
  message         String?
  createdAt       DateTime @default(now())
}

model ExternalArticleMention {
  id             String       @id @default(cuid())
  title          String
  url            String?
  sourceName     String?
  publishedAt    DateTime?
  detectedTitle  String?
  detectedYear   Int?
  detectedType   ContentType?
  tmdbId         String?
  imdbId         String?
  kpId           String?
  mentionScore   Float        @default(0)
  rawSnippet     String?
  createdAt      DateTime     @default(now())

  @@index([tmdbId])
  @@index([imdbId])
  @@index([detectedYear])
  @@index([mentionScore])
}
model SeoKeyword {
  id              String   @id @default(cuid())
  query           String
  normalizedQuery String
  impressions     Int      @default(0)
  source          String   @default("wordstat")
  intent          String   @default("UNKNOWN")
  clusterKey      String?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([normalizedQuery, source])
  @@index([status])
  @@index([clusterKey])
  @@index([intent])
  @@index([impressions])
}

model SeoCluster {
  id           String   @id @default(cuid())
  key          String   @unique
  title        String
  intent       String
  mainQuery    String
  totalDemand  Int      @default(0)
  targetType   String   @default("COLLECTION")
  targetSlug   String
  status       String   @default("ACTIVE")
  variantsJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([intent])
  @@index([status])
  @@index([targetSlug])
  @@index([totalDemand])
}
model SeoLandingPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  type            String   @default("COLLECTION")
  title           String
  h1              String
  description     String   @db.Text
  introText       String   @db.Text
  filterJson      Json?
  mainQuery       String?
  keywordVariants String[] @default([])
  totalDemand     Int      @default(0)
  minItems        Int      @default(8)
  isIndexable     Boolean  @default(true)
  sitemapIncluded Boolean  @default(true)
  status          String   @default("ACTIVE")
  aiStatus        String   @default("NOT_GENERATED")
  aiModel         String?
  aiDraftJson     Json?
  aiGeneratedAt   DateTime?
  aiError         String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([isIndexable, sitemapIncluded])
  @@index([totalDemand])
}
